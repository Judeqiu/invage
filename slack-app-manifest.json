{
  "display_information": {
    "name": "Invester",
    "description": "AI portfolio analyst — holdings, 3-axis analysis, BinDrive reports (Utarus).",
    "background_color": "#1a1a2e",
    "long_description": "Invester (Invage) is a portfolio analysis agent. Chat in DM or @mention in channels. Track holdings, run Laggards / Overpriced / Buy Opportunity analysis, save reports to BinDrive. Invite-gated onboarding. Same backend also supports Telegram."
  },
  "features": {
    "bot_user": {
      "display_name": "Invester",
      "always_online": true
    },
    "app_home": {
      "home_tab_enabled": false,
      "messages_tab_enabled": true,
      "messages_tab_read_only_enabled": false
    },
    "slash_commands": [
      {
        "command": "/help",
        "description": "Show Invester commands",
        "usage_hint": "(no arguments)",
        "url": "https://example.com/slack/commands",
        "should_escape": false
      },
      {
        "command": "/guidance",
        "description": "How to use Invester (skills and workflows)",
        "usage_hint": "[start|portfolio|analysis|research|reports|skills|admin|chat]",
        "url": "https://example.com/slack/commands",
        "should_escape": false
      },
      {
        "command": "/clear",
        "description": "Clear your conversation context",
        "usage_hint": "(no arguments)",
        "url": "https://example.com/slack/commands",
        "should_escape": false
      },
      {
        "command": "/list",
        "description": "List users (admin only)",
        "usage_hint": "(no arguments)",
        "url": "https://example.com/slack/commands",
        "should_escape": false
      },
      {
        "command": "/get",
        "description": "Show a user record (admin only)",
        "usage_hint": "[slug]",
        "url": "https://example.com/slack/commands",
        "should_escape": false
      },
      {
        "command": "/invitecode",
        "description": "Issue an invite code (admin only). Note: /invite is reserved by Slack.",
        "usage_hint": "[optional comment]",
        "url": "https://example.com/slack/commands",
        "should_escape": false
      },
      {
        "command": "/invites",
        "description": "List invite codes (admin only)",
        "usage_hint": "[all|unused|used]",
        "url": "https://example.com/slack/commands",
        "should_escape": false
      },
      {
        "command": "/admincode",
        "description": "Issue an admin onboard code (admin only)",
        "usage_hint": "[optional comment]",
        "url": "https://example.com/slack/commands",
        "should_escape": false
      },
      {
        "command": "/admincodes",
        "description": "List admin onboard codes (admin only)",
        "usage_hint": "[all|unused|used]",
        "url": "https://example.com/slack/commands",
        "should_escape": false
      },
      {
        "command": "/revoke",
        "description": "Revoke an unused admin code (admin only)",
        "usage_hint": "ADM-XXXXXXXX",
        "url": "https://example.com/slack/commands",
        "should_escape": false
      }
    ]
  },
  "oauth_config": {
    "scopes": {
      "bot": [
        "app_mentions:read",
        "channels:history",
        "channels:read",
        "chat:write",
        "commands",
        "files:write",
        "groups:history",
        "groups:read",
        "im:history",
        "im:read",
        "im:write",
        "mpim:history",
        "mpim:read",
        "mpim:write",
        "reactions:write",
        "users:read"
      ]
    }
  },
  "settings": {
    "event_subscriptions": {
      "bot_events": [
        "app_mention",
        "message.channels",
        "message.groups",
        "message.im",
        "message.mpim"
      ]
    },
    "interactivity": {
      "is_enabled": false
    },
    "org_deploy_enabled": false,
    "socket_mode_enabled": true,
    "token_rotation_enabled": false
  }
}
