{
  "name": "invage",
  "version": "0.2.0",
  "description": "AI investment portfolio analyst. Built on the Utarus agent framework (BinDrive, Telegram, per-user YAML state).",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "NODE_OPTIONS=--no-deprecation npx tsx src/index.ts",
    "webapp": "NODE_OPTIONS=--no-deprecation npx tsx src/webapp/server.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "ai",
    "investment",
    "portfolio",
    "agents",
    "telegram",
    "utarus"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "tsx": "^4.22.4",
    "utarus": "github:Judeqiu/utarus#277b996906cfbaa79577b82860f82b0e397a06ce",
    "yahoo-finance2": "^3.15.3",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
