# ── LLM ────────────────────────────────────────────────────────────────
# DeepSeek API (primary LLM) — required
DEEPSEEK_API_KEY=

# ── Framework (Utarus) ──────────────────────────────────────────────────
UTARUS_AGENT_NAME=Invester
UTARUS_LOADED_BY_HOST=1

# Prefer ABSOLUTE path so agent + BinDrive share host data
# (relative ./data resolves under node_modules/utarus).
# Example: UTARUS_DATA_ROOT=/opt/invage/data
UTARUS_DATA_ROOT=

# Public base URL for signed BinDrive report links.
# Required for save_report signed view URLs.
UTARUS_REPORTS_URL=

# ── Telegram (Binary-style) — optional ──────────────────────────────────
TELEGRAM_BOT_TOKEN=
# Comma-separated Telegram numeric user IDs (bootstrap admins)
TELEGRAM_ADMIN_IDS=

# ── Slack (Marie-style Socket Mode) — optional ──────────────────────────
# Fast path: create the app from slack-app-manifest.yaml
#   https://api.slack.com/apps → Create New App → From an app manifest
# Then copy tokens (see comments in slack-app-manifest.yaml).
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SLACK_SIGNING_SECRET=
# Comma-separated Slack user IDs (e.g. U012ABCDEF)
SLACK_ADMIN_IDS=

# ── Process mode ────────────────────────────────────────────────────────
# BOT_ONLY=true           — no CLI; keep Telegram and/or Slack running (production)
# TELEGRAM_ONLY=true      — Telegram only, no CLI, no Slack
# SLACK_ONLY=true         — Slack only, no CLI, no Telegram
# BOT_ONLY=true

# ── BinDrive webapp (separate process: npm run webapp) ──────────────────
WEBAPP_PORT=3001
SESSION_SECRET=change-me-in-production
WEBAPP_ADMIN_CREDENTIALS={"admin": "change-me"}
